[Unit]
Description=Minimal WSL Python Demo App
After=network.target

[Service]
Type=simple
User=YOUR_LINUX_USER
WorkingDirectory=/home/YOUR_LINUX_USER/WSLTest
ExecStart=/usr/bin/python3 /home/YOUR_LINUX_USER/WSLTest/main.py --loop --interval 10
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
